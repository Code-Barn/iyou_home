{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "iyou-home",
    "version": "0.2.0-SOVEREIGN-RELEASE",
    "identifier": "com.byers-brands.iyou-home",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "iyou-home",
                "width": 800,
                "height": 600
            }
        ],
        "security": {
            "csp": null
        }
    },
    "plugins": {
        "shell": {
            "scope": {
                "resource": ["$RESOURCE/*"],
                "host": [],
                "open": true
            }
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
